{
  "$schema": "https://unpkg.com/@openmrs/esm-framework/openmrs-module.schema.json",
  "name": "@openmrs/print-module",
  "version": "1.0.0",
  "description": "Print functionality for OpenMRS O3",
  "imports": [
    "@openmrs/esm-framework",
    "@openmrs/esm-patient-chart-app"
  ],
  "extensions": [
    {
      "name": "print-patient-action",
      "slot": "patient-chart-actions-slot",
      "component": "PrintPatientAction",
      "order": 100,
      "canHide": true
    }
  ],
  "extensionSlots": [
    {
      "name": "print-patient-action",
      "description": "Print patient summary and visit data"
    }
  ]
}
